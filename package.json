{
  "name": "device-activity-tracker-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Root scripts for backend + frontend",
  "scripts": {
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "start:server": "node scripts/dev-runner.mjs server",
    "start:server:with-signal": "npm run start:server:with-signal --prefix backend",
    "start:client": "node scripts/dev-runner.mjs client",
    "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "dev:with-signal": "concurrently \"npm run start:server:with-signal\" \"npm run start:client\"",
    "build": "npm run build --prefix backend && npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
